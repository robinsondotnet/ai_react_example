# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.iml
*.swp
*~

# ── Secrets & Credentials ────────────────────────────────────
# Never commit real credentials, tokens, or certificates
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.jks
*.pfx
secrets/
credentials/

# Keep the example template committed (no real values inside)
!**/.env.example

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
next-env.d.ts
*.tsbuildinfo

# ── Vite / build output ──────────────────────────────────────
dist/
dist-wc/
build/

# ── AEM SDK & local instance ─────────────────────────────────
# AEM SDK JARs and local quickstart data are large and sensitive
*.jar
crx-quickstart/
aem-author-*/
aem-publish-*/
license.properties

# ── Maven ────────────────────────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# ── Java / Eclipse ───────────────────────────────────────────
*.class
*.jar
*.war
*.ear
.classpath
.project
.settings/
.factorypath
.target
*.launch
.cproject
bin/
tmp/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Test & Coverage output ───────────────────────────────────
coverage/
reports/

# ── WordPress (Docker volumes) ───────────────────────────────
wordpress/db_data/
wordpress/wp_data/
