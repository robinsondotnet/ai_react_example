# Content provider: "mock" (default), "wordpress", or "aem"
CONTENT_PROVIDER=mock

# WordPress connection — only needed when CONTENT_PROVIDER=wordpress
# WORDPRESS_API_URL=http://localhost:8080

# AEM connection — only needed when CONTENT_PROVIDER=aem
# NEXT_PUBLIC_AEM_HOST=https://your-aem-host
# NEXT_PUBLIC_AEM_GRAPHQL_ENDPOINT=/content/_cq_graphql/your-project/endpoint.gql
# AEM_BASIC_AUTH=user:password

# CDN base URL for static asset prefix
NEXT_PUBLIC_CDN_URL=https://cdn.example.com/aem-headless
