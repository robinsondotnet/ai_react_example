# Copy to .env.local and fill in values
NEXT_PUBLIC_AEM_HOST=https://your-aem-host
NEXT_PUBLIC_AEM_GRAPHQL_ENDPOINT=/content/_cq_graphql/your-project/endpoint.gql
AEM_BASIC_AUTH=           # user:password for local dev only
NEXT_PUBLIC_CDN_URL=https://cdn.example.com/aem-headless   # CDN base for static/wc builds
